# Copy this file to .env and fill in your values before running on VPS

# --- Required ---
BOT_TOKEN=your_bot_token_from_botfather
API_ID=your_api_id_from_my.telegram.org
API_HASH=your_api_hash_from_my.telegram.org
ADMIN_IDS=123456789,987654321
DATABASE_URL=postgresql://user:password@localhost:5432/botdb
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=yourusername/your-backup-repo

# --- Optional payment details (shown to users on /plans) ---
PAYPAL_EMAIL=your@paypal.com
CRYPTO_ADDRESS=your_btc_eth_usdt_wallet_address
APPLE_PAY_INFO=Your Apple Pay instructions here
CARD_INFO=https://your-card-payment-link.com
UPI_ID=yourname@upi
